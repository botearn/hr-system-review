# --- Runtime env -------------------------------------------------------------
ENV=production

# --- Database ----------------------------------------------------------------
# Option 1 (preferred on Render / Supabase): one connection string
# Supabase → Settings → Database → Connection string → "URI" (session pooler)
DATABASE_URL=postgresql://postgres:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Option 2 (local dev): discrete vars
POSTGRES_USER=hr
POSTGRES_PASSWORD=hr_pass
POSTGRES_DB=hr_system
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis (optional, currently unused in cloud mode) ------------------------
REDIS_URL=redis://localhost:6379/0

# --- LLM provider ------------------------------------------------------------
# ollama | zhipu | deepseek | openai_compat
LLM_PROVIDER=zhipu
LLM_MODEL=glm-4-flash
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=              # 从 https://open.bigmodel.cn 获取

# DeepSeek example:
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=sk-...

# Ollama fallback (self-hosted):
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=glm4:9b

LLM_TIMEOUT_SECONDS=180

# --- Embedding ---------------------------------------------------------------
# local | zhipu | openai_compat
# Cloud default: zhipu embedding-3 (free, reuses LLM_API_KEY). 1024 dims.
EMBEDDING_PROVIDER=zhipu
# EMBEDDING_API_KEY=           # blank = reuse LLM_API_KEY
# EMBEDDING_BASE_URL=          # blank = use provider default
# EMBEDDING_MODEL_NAME=        # blank = "embedding-3" for zhipu

# Only used when EMBEDDING_PROVIDER=local (needs .[local-embed] installed):
EMBEDDING_MODEL=BAAI/bge-m3

# --- File storage ------------------------------------------------------------
# local | supabase
STORAGE_BACKEND=supabase
STORAGE_ROOT=./storage
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_KEY=       # Project Settings → API → service_role key（私密！）
SUPABASE_STORAGE_BUCKET=resumes

# --- JWT ---------------------------------------------------------------------
JWT_SECRET=change-me-in-production-to-a-random-32-byte-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# --- CORS --------------------------------------------------------------------
# Comma-separated. Set to your Vercel URL in production.
# Example: https://hr-system.vercel.app
CORS_ORIGINS=http://localhost:5173
